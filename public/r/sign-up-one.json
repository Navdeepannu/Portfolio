      "path": "components/blocks/auth/sign-up-one.tsx",
      "content": "import { Logo } from \"@/components/brand-logo\";\nimport { Button } from \"@/components/ui/button\";\nimport { Input } from \"@/components/ui/input\";\nimport { Label } from \"@/components/ui/label\";\nimport Link from \"next/link\";\n\nexport default function SignUpOne() {\n  return (\n    <section className=\"flex min-h-screen px-4 py-16 md:py-32\">\n      <div className=\"-bg-linear-16  from-zinc-50 from-50% to-white to-50% inset-0 fixed\"></div>\n      <form\n        action=\"\"\n        className=\"m-auto h-fit w-full max-w-sm overflow-hidden rounded-xl z-10 border shadow-md shadow-zinc-950/5 dark:[--color-muted:var(--color-zinc-900)]\"\n      >\n        <div className=\"bg-card -m-px border p-8 pb-6\">\n          <div className=\"text-center\">\n            <Link\n              href=\"/\"\n              aria-label=\"go home\"\n              className=\"mx-auto block w-fit \"\n            >\n              <Logo className=\"h-8 w-8 text-zinc-800\" />\n            </Link>\n            <h1 className=\"mb-1 mt-4 text-xl font-semibold\">\n              Create a Hexora Account\n            </h1>\n            <p className=\"text-sm\">Welcome! Create an account to get started</p>\n          </div>\n\n          <div className=\"mt-6 space-y-6\">\n            <div className=\"grid grid-cols-2 gap-3\">\n              <div className=\"space-y-2\">\n                <Label htmlFor=\"firstname\" className=\"block text-sm\">\n                  Firstname\n                </Label>\n                <Input\n                  type=\"text\"\n                  placeholder=\"Navdeep\"\n                  required\n                  name=\"firstname\"\n                  id=\"firstname\"\n                  className=\"\"\n                />\n              </div>\n              <div className=\"space-y-2\">\n                <Label htmlFor=\"lastname\" className=\"block text-sm\">\n                  Lastname\n                </Label>\n                <Input\n                  type=\"text\"\n                  placeholder=\"Singh\"\n                  required\n                  name=\"lastname\"\n                  id=\"lastname\"\n                />\n              </div>\n            </div>\n\n            <div className=\"space-y-2\">\n              <Label htmlFor=\"email\" className=\"block text-sm\">\n                Email\n              </Label>\n              <Input\n                type=\"email\"\n                placeholder=\"youremail@domain.com\"\n                required\n                name=\"email\"\n                id=\"email\"\n              />\n            </div>\n\n            <div className=\"space-y-0.5\">\n              <div className=\"flex items-center justify-between\">\n                <Label htmlFor=\"pwd\" className=\"text-sm\">\n                  Password\n                </Label>\n                <Button asChild variant=\"link\" size=\"sm\">\n                  <Link href=\"#\">Forgot your Password ?</Link>\n                </Button>\n              </div>\n              <Input\n                type=\"password\"\n                required\n                name=\"pwd\"\n                id=\"pwd\"\n                placeholder=\"Create a password\"\n                className=\"input sz-md variant-mixed\"\n              />\n            </div>\n\n            <Button className=\"w-full ring-2 ring-ring/50  shadow-lg shadow-black/30\">\n              Sign In\n            </Button>\n          </div>\n\n          <div className=\"my-6 grid grid-cols-[1fr_auto_1fr] items-center gap-3\">\n            <hr className=\"border-dashed\" />\n            <span className=\"text-muted-foreground text-xs\">\n              Or continue With\n            </span>\n            <hr className=\"border-dashed\" />\n          </div>\n\n          <div className=\"grid grid-cols-2 gap-3\">\n            <Button type=\"button\" variant=\"outline\">\n              <svg\n                xmlns=\"http://www.w3.org/2000/svg\"\n                width=\"800px\"\n                height=\"800px\"\n                viewBox=\"-3 0 262 262\"\n                preserveAspectRatio=\"xMidYMid\"\n              >\n                <path\n                  d=\"M255.878 133.451c0-10.734-.871-18.567-2.756-26.69H130.55v48.448h71.947c-1.45 12.04-9.283 30.172-26.69 42.356l-.244 1.622 38.755 30.023 2.685.268c24.659-22.774 38.875-56.282 38.875-96.027\"\n                  fill=\"#4285F4\"\n                />\n                <path\n                  d=\"M130.55 261.1c35.248 0 64.839-11.605 86.453-31.622l-41.196-31.913c-11.024 7.688-25.82 13.055-45.257 13.055-34.523 0-63.824-22.773-74.269-54.25l-1.531.13-40.298 31.187-.527 1.465C35.393 231.798 79.49 261.1 130.55 261.1\"\n                  fill=\"#34A853\"\n                />\n                <path\n                  d=\"M56.281 156.37c-2.756-8.123-4.351-16.827-4.351-25.82 0-8.994 1.595-17.697 4.206-25.82l-.073-1.73L15.26 71.312l-1.335.635C5.077 89.644 0 109.517 0 130.55s5.077 40.905 13.925 58.602l42.356-32.782\"\n                  fill=\"#FBBC05\"\n                />\n                <path\n                  d=\"M130.55 50.479c24.514 0 41.05 10.589 50.479 19.438l36.844-35.974C195.245 12.91 165.798 0 130.55 0 79.49 0 35.393 29.301 13.925 71.947l42.211 32.783c10.59-31.477 39.891-54.251 74.414-54.251\"\n                  fill=\"#EB4335\"\n                />\n              </svg>\n              <span>Google</span>\n            </Button>\n            <Button type=\"button\" variant=\"outline\">\n              <svg\n                xmlns=\"http://www.w3.org/2000/svg\"\n                width=\"800px\"\n                height=\"800px\"\n                viewBox=\"0 -3.5 256 256\"\n                preserveAspectRatio=\"xMinYMin meet\"\n              >\n                <g fill=\"#161614\">\n                  <path d=\"M127.505 0C57.095 0 0 57.085 0 127.505c0 56.336 36.534 104.13 87.196 120.99 6.372 1.18 8.712-2.766 8.712-6.134 0-3.04-.119-13.085-.173-23.739-35.473 7.713-42.958-15.044-42.958-15.0